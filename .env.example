# Copy to .env and adjust as needed (up.sh does this automatically).

# rubixgoplatform release version the node image downloads.
# Bump to any tag at github.com/rubixchain/rubixgoplatform/releases to update.
RUBIX_VERSION=v1.0.0

# Node image tag. Point at a registry (e.g. ghcr.io/you/rubix-node:v1.0.0) and
# push with scripts/build-node-image.sh to pull instead of building on each host.
RUBIX_NODE_IMAGE=network-coin/rubix-node:v1.0.0

# Rubix network the nodes join: testnet | localnet | mainnet
NETWORK_MODE=testnet

# IP announced to the IPFS DHT. Leave blank — up.sh auto-detects it.
EXTERNAL_IP=
